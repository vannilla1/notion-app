<?xml version="1.0" encoding="utf-8"?>
<!--
  Splash screen logo — plné PRPL CRM logo (fialový gradient + "P" + sparkles),
  zhodné so zobrazením v Bubblewrap TWA verzii a na web/iOS PWA.

  Zdroj: client/public/icons/icon-512x512.png, kopírovaný do mipmap-*/ic_splash_src.png
  v rôznych densitách (hdpi 288px, xhdpi 384px, xxhdpi 432px, xxxhdpi 512px) aby
  Android pri splash screen rendering (192dp visible area) vybral najvhodnejšiu
  rezolúciu a nebol blurry.

  Android 12+ splash API ho kruhovo orezáva; safe zone (center 66dp/108dp) obsahuje
  "P" s gradientom, takže orezanie vyzerá čisto. Sparkles v rohoch sa možno odrežú.
-->
<bitmap xmlns:android="http://schemas.android.com/apk/res/android"
    android:src="@mipmap/ic_splash_src"
    android:gravity="center" />
