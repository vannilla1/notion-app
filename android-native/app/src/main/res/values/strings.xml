<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name">Prpl CRM</string>

    <!-- Web URL ktorý WebView načíta. Musí zodpovedať Digital Asset Links host,
         aby deep linking + intent filter v AndroidManifest fungoval bez URL baru. -->
    <string name="webapp_url">https://prplcrm.eu/app</string>

    <!-- Backend API base URL. POZOR: toto je SAMOSTATNÁ doména od webapp_url —
         frontend beží na prplcrm.eu (Render static site), backend API na
         perun-crm-api.onrender.com (Render web service). Toto používajú natívne
         OkHttp requesty (napr. FCM register) ktoré NEIDÚ cez WebView. WebView
         volá API cez relative URL a CORS ich rieši na úrovni Render routingu. -->
    <string name="api_base_url">https://perun-crm-api.onrender.com</string>

    <!-- Notification channel — FCM použije tento ID ako default. -->
    <string name="default_notification_channel_id">prpl_notifications</string>
    <string name="default_notification_channel_name">Notifikácie</string>
    <string name="default_notification_channel_description">Upozornenia na úlohy, správy a aktivitu v tíme.</string>

    <!-- User-facing error texty -->
    <string name="offline_title">Žiadne pripojenie</string>
    <string name="offline_message">Skontrolujte internetové pripojenie a skúste znova.</string>
    <string name="retry">Skúsiť znova</string>
</resources>
