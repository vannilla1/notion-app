# Skopíruj tento súbor na `keystore.properties` (ktorý je v .gitignore) a vyplň
# heslami z Bubblewrap TWA keystore (android/android.keystore) — rovnaké heslá
# musíme použiť, aby Google Play Store prijal AAB ako update appky s
# package name `eu.prplcrm.app`.
#
# Alias bol nastavený Bubblewrapom pri TWA inite: `android`. Keystore password
# a key password môžu byť rovnaké alebo rôzne — závisí od toho, čo si zadal
# pri `bubblewrap init` v apríli.
#
# Alternatívne: namiesto tohto súboru môžeš exportovať env vars:
#   export KEYSTORE_PASSWORD='...'
#   export KEY_PASSWORD='...'
# Gradle build.gradle.kts ich spadne do signingConfig keď keystore.properties
# neexistuje.

storePassword=CHANGE_ME
keyAlias=android
keyPassword=CHANGE_ME
