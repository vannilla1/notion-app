# Server configuration
PORT=5001
NODE_ENV=development

# JWT Secret (generate a random string for production)
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/prplcrm

# CORS origins (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Email for critical error alerts (optional — SuperAdmin notifications when
# >10 new errors arrive within 1h window). Uses existing adminEmailService.
ERROR_ALERT_EMAIL=

# Logging level (error, warn, info, http, verbose, debug)
LOG_LEVEL=info

# Rate limiting (optional - set to 'true' to skip in development)
SKIP_RATE_LIMIT=false

# Stripe billing (optional - billing features disabled without these)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Create products/prices in Stripe Dashboard, then paste IDs here:
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# ─── OAuth: Sign in with Google ───────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Vytvor "Web application" client (web flow) a "iOS" client (pre native iOS).
# Authorized redirect URIs: https://prplcrm-api.onrender.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://prplcrm-api.onrender.com/api/auth/google/callback
GOOGLE_IOS_CLIENT_ID=                   # pre POST /api/auth/google/native (iOS)

# ─── OAuth: Sign in with Apple ────────────────────────────────────
# Apple Developer → Certificates, Identifiers & Profiles
#   1. App ID:    eu.prplcrm.app  (Sign In with Apple capability ON)
#   2. Service ID: eu.prplcrm.signin (web flow, Return URL = backend callback)
#   3. Key:       Vytvor Sign In with Apple key, stiahni .p8 súbor
# .p8 obsah je PEM private key. Skopíruj cely PEM (vrátane -----BEGIN... -----END)
# do APPLE_PRIVATE_KEY hodnoty (na Render-i ako multi-line value).
APPLE_TEAM_ID=                          # 10-char Apple Team ID
APPLE_KEY_ID=                           # 10-char Sign In with Apple Key ID
APPLE_PRIVATE_KEY=                      # PEM content z .p8 súboru
APPLE_SERVICE_ID=eu.prplcrm.signin      # Service ID pre web flow (audience)
APPLE_APP_BUNDLE_ID=eu.prplcrm.app      # App Bundle ID pre iOS native (audience)
APPLE_OAUTH_REDIRECT_URI=https://prplcrm-api.onrender.com/api/auth/apple/callback

# ─── State HMAC pre OAuth flow ────────────────────────────────────
# Optional — keď nie je nastavený, derivuje sa z JWT_SECRET cez HMAC.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
OAUTH_STATE_SECRET=

# Frontend URL pre post-OAuth redirect (token v hash fragmente)
CLIENT_URL=https://prplcrm.eu
