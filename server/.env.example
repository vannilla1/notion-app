# Server configuration
PORT=5001
NODE_ENV=development

# JWT Secret (generate a random string for production)
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/prplcrm

# CORS origins (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Email for critical error alerts (optional — SuperAdmin notifications when
# >10 new errors arrive within 1h window). Uses existing adminEmailService.
ERROR_ALERT_EMAIL=

# Logging level (error, warn, info, http, verbose, debug)
LOG_LEVEL=info

# Rate limiting (optional - set to 'true' to skip in development)
SKIP_RATE_LIMIT=false

# Stripe billing (optional - billing features disabled without these)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Create products/prices in Stripe Dashboard, then paste IDs here:
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
