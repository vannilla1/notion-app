node_modules
.env
.env.local
dist

# APNs private keys
*.p8

# Logs
logs
*.log

# Uploads (keep directory structure)
server/uploads/*
!server/uploads/.gitkeep
!server/uploads/avatars/.gitkeep

# Android TWA build artifacts (Bubblewrap)
# Keep config (twa-manifest.json, AndroidManifest.xml), exclude build outputs + keystore.
# Keystore is SECURITY-CRITICAL — losing it means we can never update the app on Play Store.
# Always back it up to 2 offline locations.
android/build/
android/app/build/
android/.gradle/
android/local.properties
android/*.keystore
android/keystore-*.jks
android/*.aab
android/*.apk
android/*.idsig

# Android native Kotlin wrapper build artifacts
android-native/build/
android-native/app/build/
android-native/.gradle/
android-native/local.properties
android-native/*.keystore
android-native/keystore.properties
android-native/*.aab
android-native/*.apk
android-native/*.idsig
# Firebase config is committed per-file — google-services.json je OK commit-ovať
# (obsahuje len public API key), ALE pre istotu radšej nie (projekt je proprietary).
android-native/app/google-services.json

# Firebase + keystore credentials — všetko čo neleží v repo ale musí sa niekde
# uložiť. Obsah tu nikdy necommituj, na Render idú cez env variables.
secrets/

