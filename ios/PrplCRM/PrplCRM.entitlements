<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- APNs environment — "production" pre App Store builds (Release scheme).
	     Debug buildy stále dostanú sandbox APNs cez Xcode automatic provisioning
	     (dev profile vie handle-nut "production" value aj pre sandbox). Pre
	     TestFlight/App Store je "production" povinné aby production APNs server
	     prijal notifikácie. -->
	<key>aps-environment</key>
	<string>production</string>

	<!-- Universal Links — iOS overí apple-app-site-association na
	     https://prplcrm.eu/.well-known/apple-app-site-association pri inštalácii
	     appky. Keď Safari potom navštívi URL matchujúcu `paths`, iOS ju
	     automaticky presmeruje do natívnej appky namiesto Safari taba.
	     Použitie: post-OAuth redirect z Google sa vráti priamo do appky bez
	     ručného prepnutia z Safari. -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:prplcrm.eu</string>
	</array>
</dict>
</plist>
